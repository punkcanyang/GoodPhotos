{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-stat",
    "process:default",
    "updater:default",
    {
      "identifier": "fs:allow-read",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/**"
        },
        {
          "path": "**/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/**"
        },
        {
          "path": "**/*"
        }
      ]
    },
    "fs:read-all"
  ]
}
